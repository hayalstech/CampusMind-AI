# PitchPulse Environment Configuration
# Copy this file to .env.local and add your actual API keys

# Football API Configuration
# Get your API key from: https://www.api-football.com/
NEXT_PUBLIC_FOOTBALL_API_KEY=your_api_key_here

# Optional: API-Football RapidAPI Key (alternative)
# NEXT_PUBLIC_RAPIDAPI_KEY=your_rapidapi_key_here

# Optional: Football-Data.org API Key
# Get your API key from: https://www.football-data.org/
# NEXT_PUBLIC_FOOTBALL_DATA_API_KEY=your_api_key_here

# Application Settings
NEXT_PUBLIC_APP_NAME=PitchPulse
NEXT_PUBLIC_POLLING_INTERVAL=60000
